        object Btn_about_way111: TButton
          Left = 93
          Height = 25
          Hint = '燃线法权重算法说明'#10'这其实是作者自创的燃线法，'#10'燃线法，就是设想，节点与线段是导火线是燃烧的线，且匀速直线运动，'#10'又或者设想是金属铜导线，通电后，以光速运动，最先到达的就是最快路径FastLine'#10#10'原先的版本是没有权重的，点与边的权重是现在才添加上去的，'#10'由于权重可能有多种组合解释，现在以下面为解释：'#10'点的权重就是，经过此点时路径增加的值，'#10'边的权重，就是边长再相乘的乘数倍数。'#10'只在作者自创的燃线法添加权重功能，'#10'别的算法暂没空去做了，以后再理'#10#10'因为作者自已闭门造车想出燃线法，再去网上寻找最短路径算法，发觉与已存在的A-Star算法十分相似，实际上又难以明确，于是作出程序来实用，'#10'理论上归属哪个算法，不太明确。'#10'关键是实际上能找到最短的最快的路径，实用就行了。'
          Top = 10
          Width = 50
          Caption = 'A-Star2'
          Font.Height = -11
          Font.Name = 'Sans'
          Font.Style = [fsBold]
          ParentFont = False
          ParentShowHint = False
          ShowHint = True
          TabOrder = 7
          OnClick = Btn_about_way111Click
        end
        object RadioBtn_way1: TRadioButton
          Left = 0
          Height = 23
          Hint = 'A-Star算法说明2'#10'这其实是作者自创的燃线法，因为作者自已闭门造车想出燃线法，再去网上寻找最短路径算法，'#10'发觉与已存在的A-Star算法十分相似，实际上又难以明确，于是作出程序来实用，'#10'理论上归属哪个算法，不太明确。'#10'关键是实际上能找到最短的最快的路径，实用就行了。'#10'燃线法，就是设想，节点与线段是导火线是燃烧的线，且匀速直线运动，'#10'又或者设想是金属铜导线，通电后，以光速运动，'#10'最先到达的就是最快路径FastLine'
          Top = 38
          Width = 60
          Caption = 'A-Star'
